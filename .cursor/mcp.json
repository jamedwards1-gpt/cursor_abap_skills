{
  "mcpServers": {
    "cds-mcp": {
      "command": "npx",
      "args": ["-y", "@cap-js/mcp-server"]
    },
    "abap-adt": {
      "command": "node",
      "args": [
        "node_modules/@mcp-abap-adt/core/bin/mcp-abap-adt.js",
        "--transport=stdio",
        "--env-path",
        ".secrets/btp-abap.env",
        "--exposition=readonly,high"
      ]
    }
  }
}
